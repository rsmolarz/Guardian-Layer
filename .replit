modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["pnpm", "--filter", "@workspace/api-server", "run", "start"]
build = ["sh", "-c", "BASE_PATH=/ PORT=19337 pnpm --filter @workspace/guardianlayer run build && pnpm --filter @workspace/api-server run build"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["google-mail:1.0.0", "google-drive:1.0.0", "google-calendar:1.0.0", "google-docs:1.0.0", "google-sheet:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
JWT_SECRET = "065d5f3079f8efd73995db66b6610283ad182ac0357fb94642f9d8b18c4313b447dbfbec4067d2fc0b3a6f2e04217811"
