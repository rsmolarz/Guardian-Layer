# Guardian-Layer environment template
# Copy to .env on the deploy target and fill in real values.
# The server will fail to start if any "REQUIRED AT BOOT" value is missing.

# ------------------------------------------------------------------
# REQUIRED AT BOOT — server throws and exits without these
# ------------------------------------------------------------------
NODE_ENV=production
PORT=8080
DATABASE_URL=postgresql://guardianlayer:CHANGEME@localhost:5433/guardianlayer
JWT_SECRET=                      # generate: openssl rand -base64 48
APP_ENCRYPTION_KEY=              # generate: openssl rand -hex 32
                                 # WARNING: rotating this after data is written =
                                 # silent decrypt failures in vault, gateway,
                                 # remote-machines, node-diagnostics, tailscale.

# OpenAI integration — module-load throw if either is missing.
# Placeholder values boot the server; AI routes 500 at request time until
# a real key is provided.
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=sk-placeholder-replace-before-using-ai

# ------------------------------------------------------------------
# Core app (server boots without, specific features fail)
# ------------------------------------------------------------------
SUPERADMIN_INITIAL_PASSWORD=     # used on first boot to seed admin;
                                 # after first login, REMOVE this line or the
                                 # seed will re-sync and revert UI password changes
BACKUP_ADMIN_KEY=                # random 32+ chars, protects /api/backups admin endpoints
APP_URL=https://guardian-layer.com
BACKUP_DIR=/opt/guardianlayer/backups
WORKSPACE_DIR=/opt/guardianlayer

# ------------------------------------------------------------------
# Auth / payments — fill in what you use
# ------------------------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
STRIPE_TEST_API_KEY=

# ------------------------------------------------------------------
# Optional third-party integrations — per feature
# ------------------------------------------------------------------
ABUSEIPDB_API_KEY=
HIBP_API_KEY=
VIRUSTOTAL_API_KEY=
# TAILSCALE_API_KEY: if set, on every boot the server fetches your
# tailnet's device list and inserts new ones into remote_machines.
TAILSCALE_API_KEY=
NAMESILO_API_KEY=
DID_CLIENT_ID=
DID_CLIENT_SECRET=
GOOGLE_MAIL_ACCESS_TOKEN=

# MedInvest OAuth
MEDINVEST_BASE_URL=
MEDINVEST_CLIENT_ID=
MEDINVEST_CLIENT_SECRET=
MEDINVEST_REDIRECT_URI=https://guardian-layer.com/api/integrations/medinvest/callback
